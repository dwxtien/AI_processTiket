    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  // 1. Lấy toàn bộ văn bản email từ node AI Agent2 liền trước\n  const fullText = item.json.output || '';\n\n  let subject = '';\n  let body = '';\n\n  // 2. Dùng Regex để tách phần Tiêu đề và phần Nội dung dựa trên cấu trúc text\n  const match = fullText.match(/^\\*\\*Tiêu đề:\\*\\*\\s*(.*?)\\n\\n([\\s\\S]*)$/);\n\n  if (match) {\n    subject = match[1].trim(); // Lấy phần nằm sau \"**Tiêu đề:**\"\n    body = match[2].trim();    // Toàn bộ phần còn lại ở phía dưới\n  } else {\n    // Fallback nếu không khớp định dạng regex\n    subject = \"Thông báo khắc phục lỗi hệ thống (P0)\";\n    body = fullText;\n  }\n\n  // 3. Lấy dữ liệu từ node \"Parse JSON từ AI\" ở phía trước\n  let targetNode;\n  try {\n    targetNode = $(\"Parse JSON từ AI\").first();\n  } catch (e) {\n    targetNode = { json: {} };\n  }\n  \n  // 4. Gộp tất cả lại vào Output mới\n  item.json.email_subject = subject;\n  item.json.email_body = body;\n  \n  // Giữ lại các trường phân tích cũ của bạn\n  item.json.category = targetNode.json.category || 'incident';\n  item.json.priority = targetNode.json.priority || 'P0';\n  item.json.sentiment = targetNode.json.sentiment || 'negative';\n  item.json.urgencyScore = targetNode.json.urgencyScore || null;\n  item.json.businessImpact = targetNode.json.businessImpact || null;\n  item.json.summary = targetNode.json.summary || '';\n  item.json.recommendedOwner = targetNode.json.recommendedOwner || '';\n  item.json.needsHumanApproval = targetNode.json.needsHumanApproval !== undefined ? targetNode.json.needsHumanApproval : false;\n\n  // Xóa bớt trường output cũ cho gọn bảng dữ liệu (tùy chọn)\n  delete item.json.output; \n\n  return item;\n});"
