      "parameters": {
        "jsCode": "return items.map(item => {\n  const ticket = item.json;\n  item.json.aiAnalysisPrompt = `Bạn là AI Support Operations Analyst. Hãy phân tích ticket sau và CHỈ trả về JSON hợp lệ, không markdown.\\n\\nSchema JSON:\\n{\\n  \"category\": \"bug|incident|feature_request|billing|question\",\\n  \"priority\": \"P0|P1|P2|P3\",\\n  \"sentiment\": \"negative|neutral|positive\",\\n  \"urgencyScore\": 0-100,\\n  \"businessImpact\": \"low|medium|high|critical\",\\n  \"entities\": {\"systems\": [], \"deadline\": \"\", \"stakeholders\": []},\\n  \"summary\": \"tóm tắt 1 câu\",\\n  \"recommendedOwner\": \"Engineering|Customer Success|Sales|Finance\",\\n  \"needsHumanApproval\": true|false\\n}\\n\\nTicket ID:$input.first().json.body.ticketId \\nKhách hàng: $input.first().json.body.customerName\\nKênh: $input.first().json.body.channel\\nSLA giờ: $input.first().json.body.slaHours\\nNội dung: $input.first().json.body.message`;\n  return item;\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        64
      ],
      "id": "0c87f98e-3aac-4d19-9efb-f40c83661b85",
      "name": "Tạo prompt phân tích"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  // 1. Lấy chuỗi chữ thô từ node AI Agent trước đó\n  const raw = item.json.output || '{}';\n  \n  let analysis = {};\n  try {\n    // 2. Tìm vị trí dấu { đầu tiên và } cuối cùng để tự động cắt lấy khối JSON bôi đen\n    const startPos = raw.indexOf('{');\n    const endPos = raw.lastIndexOf('}');\n    \n    if (startPos !== -1 && endPos !== -1) {\n      const jsonString = raw.substring(startPos, endPos + 1);\n      analysis = JSON.parse(jsonString);\n    } else {\n      throw new Error(\"Không tìm thấy cấu trúc JSON dạng {} trong chuỗi văn bản.\");\n    }\n  } catch (error) {\n    // Fallback nếu chuỗi hoàn toàn lỗi không thể xử lý\n    analysis = {\n      category: 'incident',\n      priority: 'P1',\n      sentiment: 'negative',\n      urgencyScore: 50,\n      businessImpact: 'medium',\n      entities: { systems: [], deadline: null, stakeholders: [] },\n      summary: 'Lỗi parse dữ liệu thô',\n      recommendedOwner: 'Support',\n      needsHumanApproval: false,\n      parseFallback: true,\n      errorDetail: error.message\n    };\n  }\n\n  // 3. Đưa TẤT CẢ các thuộc tính ra ngoài layer cao nhất của item.json\n  item.json.category = analysis.category;\n  item.json.priority = analysis.priority;\n  item.json.sentiment = analysis.sentiment;\n  item.json.urgencyScore = analysis.urgencyScore;\n  item.json.businessImpact = analysis.businessImpact;\n  item.json.entities = analysis.entities; // Đã thêm bóc tách entities\n  item.json.summary = analysis.summary;\n  item.json.recommendedOwner = analysis.recommendedOwner;\n  item.json.needsHumanApproval = analysis.needsHumanApproval;\n\n  // Giữ lại bản gốc phòng trường hợp cần dùng\n  item.json.analysis = analysis;\n\n  return item;\n});"
      },
